# HTTP
HTTP_ADDR=:8080

# Database (Postgres + PostGIS в docker-compose)
DATABASE_URL=postgres://goyda:goyda@localhost:5432/goyda?sslmode=disable

# JWT (смените в проде)
JWT_SECRET=change-me-to-a-long-random-string

# CORS (через запятую)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Yandex Cloud Foundation Models / LLM (опционально)
YANDEX_FOLDER_ID=
YANDEX_API_KEY=

# Yandex Weather / Routing (опционально; если пусто, fallback в mock)
YANDEX_WEATHER_API_KEY=
YANDEX_ROUTING_API_KEY=
